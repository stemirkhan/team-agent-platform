APP_NAME=Team Agent Platform API
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1

POSTGRES_DB=agent_marketplace
POSTGRES_USER=agent_marketplace
POSTGRES_PASSWORD=agent_marketplace
POSTGRES_PORT=5432

REDIS_PORT=6379

BACKEND_PORT=8000
WEB_PORT=3000

DATABASE_URL=postgresql+psycopg://agent_marketplace:agent_marketplace@localhost:5432/agent_marketplace
REDIS_URL=redis://localhost:6379/0
HOST_EXECUTOR_BASE_URL=http://host.containers.internal:8765
WORKSPACE_ROOT=~/.team-agent-platform/workspaces
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
JWT_SECRET_KEY=dev-secret-key-change-me-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
API_BASE_URL=http://localhost:8000/api/v1
HOST_EXECUTOR_HOST=0.0.0.0
HOST_EXECUTOR_PORT=8765
